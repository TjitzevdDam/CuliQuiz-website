{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "installCommand": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },

    { "source": "/events", "destination": "/nieuws.html", "permanent": true },
    { "source": "/events.html", "destination": "/nieuws.html", "permanent": true },
    { "source": "/blog", "destination": "/nieuws.html", "permanent": true },
    { "source": "/blog/:slug", "destination": "/nieuws.html", "permanent": true },

    { "source": "/contact", "destination": "/wat-leveren-we.html#aanvraag", "permanent": true },
    { "source": "/contact.html", "destination": "/wat-leveren-we.html#aanvraag", "permanent": true },

    { "source": "/spel-elementen", "destination": "/wat-leveren-we.html", "permanent": true },
    { "source": "/spel-elementen.html", "destination": "/wat-leveren-we.html", "permanent": true },

    { "source": "/top-100", "destination": "/top100.html", "permanent": true },
    { "source": "/top100", "destination": "/top100.html", "permanent": true },
    { "source": "/culiquiz-top100", "destination": "/top100.html", "permanent": true },
    { "source": "/culiquiz-top-100", "destination": "/top100.html", "permanent": true },

    { "source": "/finale", "destination": "/nieuws/finale-2023-2024.html", "permanent": true },
    { "source": "/finale-2024", "destination": "/nieuws/finale-2023-2024.html", "permanent": true },
    { "source": "/finale-2025", "destination": "/nieuws/battle-2025.html", "permanent": true },

    { "source": "/partners", "destination": "/ambassadeurs.html", "permanent": true },
    { "source": "/partners.html", "destination": "/ambassadeurs.html", "permanent": true },
    { "source": "/ambassadeur", "destination": "/ambassadeurs.html", "permanent": true },

    { "source": "/app", "destination": "/scholen.html", "permanent": true },
    { "source": "/download", "destination": "/scholen.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
